# Rename this file to .env and fill in real values. Never commit .env to git.

# Flask
SECRET_KEY=change-this-to-a-random-64-character-string
FLASK_ENV=development
FLASK_DEBUG=1

# Database (leave unset to auto-use instance/sentinelx.db next to app.py)
# DATABASE_URL=sqlite:////absolute/path/to/sentinelx.db

# Groq AI (get a free key at https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Security
SESSION_COOKIE_SECURE=False
RATE_LIMIT_PER_MINUTE=30
